<style>
    .login-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 70vh;
    }

    .login-box {
        background: #fff;
        padding: 40px;
        border-radius: 12px;
        border: 1px solid #e0e0e0;
        box-shadow: 0 8px 16px rgba(0,0,0,0.1);
        width: 100%;
        max-width: 400px;
        text-align: center;
        font-family: 'Segoe UI', sans-serif;
    }

        .login-box h2 {
            color: #2d6a4f;
            margin-bottom: 25px;
        }

        .login-box input {
            width: 100%;
            padding: 12px;
            margin: 10px 0;
            border: 1px solid #ccc;
            border-radius: 6px;
            box-sizing: border-box;
        }

        .login-box button {
            width: 100%;
            padding: 12px;
            background: #2d6a4f;
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 16px;
            font-weight: bold;
            margin-top: 10px;
        }

            .login-box button:hover {
                background: #235a42;
            }
</style>

<div class="login-container">
    <div class="login-box">
        <h2>Logowanie</h2>
        <form id="loginForm">
            <input type="email" id="email" placeholder="Email" required />
            <input type="password" id="password" placeholder="Password" required />
            <button type="submit">Zaloguj</button>
        </form>

        <div style="margin-top: 15px; text-align: center;">
            <p>Nie masz konta? <a href="/Account/Register" style="color: #2e7d32; font-weight: bold;">Zarejestruj się</a></p>
        </div>
    </div>
</div>

<script src="/js/login.js"></script>