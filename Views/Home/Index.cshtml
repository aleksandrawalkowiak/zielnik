@{
    ViewData["Title"] = "Panel Główny";
}

<div style="text-align: center; margin-top: 20px; margin-bottom: 40px; font-family: 'Segoe UI', sans-serif;">
    <h1 style="color: #2e7d32; font-size: 2.8em; font-weight: bold; margin-bottom: 10px;">
        🌿 Zielnik — Panel Główny
    </h1>
    <p style="color: #666; font-size: 1.2em; max-width: 600px; margin: 0 auto;">
        Zarządzaj swoimi domowymi uprawami, planuj podlewanie i dbaj o zieloną przestrzeń в prosty sposób.
    </p>
</div>

<div style="display: flex; gap: 25px; justify-content: center; flex-wrap: wrap; margin-bottom: 40px; font-family: 'Segoe UI', sans-serif;">

    <div onclick="window.location='/GardensPage'" style="background: #e3f2fd; border: 2px solid #90caf9; border-radius: 12px; padding: 25px; width: 240px; text-align: center; cursor: pointer; transition: transform 0.2s; box-shadow: 0 4px 8px rgba(0,0,0,0.05);">
        <span style="font-size: 3em;">🏡</span>
        <h3 style="margin: 15px 0 10px 0; color: #0d47a1;">Moje Ogrody</h3>
        <p style="color: #555; font-size: 0.9em; margin: 0;">Przeglądaj swoje strefy zieleni, edytuj ich nazwy i zarządzaj układem roślin.</p>
    </div>

    <div onclick="window.location='/PlantsPage'" style="background: #e8f5e9; border: 2px solid #a5d6a7; border-radius: 12px; padding: 25px; width: 240px; text-align: center; cursor: pointer; transition: transform 0.2s; box-shadow: 0 4px 8px rgba(0,0,0,0.05);">
        <span style="font-size: 3em;">🌱</span>
        <h3 style="margin: 15px 0 10px 0; color: #2e7d32;">Baza Roślin</h3>
        <p style="color: #555; font-size: 0.9em; margin: 0;">Katalog gatunków. Dodawaj nowe rośliny do globalnej bazy danych i określaj parametry.</p>
    </div>

    <div onclick="window.location='/TasksPage'" style="background: #fff8e1; border: 2px solid #ffe082; border-radius: 12px; padding: 25px; width: 240px; text-align: center; cursor: pointer; transition: transform 0.2s; box-shadow: 0 4px 8px rgba(0,0,0,0.05);">
        <span style="font-size: 3em;">📅</span>
        <h3 style="margin: 15px 0 10px 0; color: #f57c00;">Harmonogram</h3>
        <p style="color: #555; font-size: 0.9em; margin: 0;">Lista zadań opiekuńczych, kalendarz podlewania i obowiązków na dzisiejszy dzień.</p>
    </div>

</div>

<div style="max-width: 820px; margin: 0 auto; background: #fafafa; border: 1px dashed #ccc; padding: 15px; border-radius: 8px; text-align: center; color: #777; font-size: 0.9em; font-family: 'Segoe UI', sans-serif;">
    💡 <b>Wskazówka:</b> Kliknij dowolny kafelek powyżej, aby przejść do dedykowanego widoku aplikacji. Interfejs jest w pełni responsywny.
</div>